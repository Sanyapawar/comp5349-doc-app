# ── Flask ─────────────────────────────────────────────────────────────────────
# Secret key used to sign session cookies. Change this to a random string.
FLASK_SECRET_KEY=change-me-to-a-random-secret

# ── AWS ───────────────────────────────────────────────────────────────────────
# AWS region where your resources are deployed (AWS Academy default: us-east-1)
AWS_REGION=us-east-1

# S3 bucket name where uploaded PDFs are stored
S3_BUCKET_NAME=your-s3-bucket-name

# ── RDS / PostgreSQL ──────────────────────────────────────────────────────────
# RDS endpoint (e.g. mydb.xxxxxxxxxxxx.us-east-1.rds.amazonaws.com)
DB_HOST=your-rds-endpoint.rds.amazonaws.com

# PostgreSQL port (default: 5432)
DB_PORT=5432

# Database name created on the RDS instance
DB_NAME=docdb

# Database master username
DB_USER=postgres

# Database master password
DB_PASSWORD=your-db-password

# ── OpenAI ────────────────────────────────────────────────────────────────────
# API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-api-key
